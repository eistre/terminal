{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/Tallinn",
  "schedule": [
    "* 0-11 1 * *"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "rangeStrategy": "bump",
  "dependencyDashboard": true,
  "prConcurrentLimit": 5,
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "* 0-11 * * 0"
    ]
  },
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "minimumReleaseAge": "1 day",
      "internalChecksFilter": "strict"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm minor and patch updates"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions updates"
    },
    {
      "matchManagers": [
        "terraform"
      ],
      "groupName": "Terraform updates"
    },
    {
      "matchManagers": [
        "docker-compose",
        "dockerfile",
        "helm-values"
      ],
      "groupName": "Container image updates"
    },
    {
      "matchManagers": [
        "dockerfile",
        "npm",
        "nvm"
      ],
      "matchPackageNames": [
        "node",
        "pnpm"
      ],
      "groupName": "Runtime version updates"
    }
  ]
}
